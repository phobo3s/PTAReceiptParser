# PTA Receipt Parser — Makine-spesifik ayarlar
# Bu dosyayı config.toml olarak kopyalayın ve düzenleyin.
# config.toml .gitignore'dadır, repoya girmez.

[paths]
# OCR cache klasörleri — ayrı data repo kullanıyorsanız tam path verin
# ocr_cache       = "C:/PTAReceiptParser-data/.ocr_cache"
# ocr_cache_trocr = "C:/PTAReceiptParser-data/.ocr_cache_trocr"
ocr_cache       = ".ocr_cache"
ocr_cache_trocr = ".ocr_cache_trocr"

# Kural dosyaları
# rules         = "C:/PTAReceiptParser-data/rules.toml"
rules           = "rules.toml"
rules_learned   = "rules_learned.toml"

# Varsayılan hesap adı (kural eşleşmezse)
default_account = "Gider:Bilinmeyen"

# PPOCRLabel data klasörü (Label.txt, rec_gt.txt, Cache.cach, crop_img/)
# ppocr_data = "C:/PTAReceiptParser-data/Receipts"
ppocr_data      = "PPOCRLabel_Data/Receipts"
